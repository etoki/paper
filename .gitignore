# PDFs (large, stored elsewhere)
*.pdf
# ...except under simulation/data/
!simulation/data/**/*.pdf
# ...and pre-registration PDFs (small, OSF supplementary uploads)
!simulation/docs/pre_registration/*.pdf
# ...and journal-specific anonymised cover letters (small, submission-ready)
!metaanalysis/paper_v2/cover_letter_*_anon.pdf

# Claude Code local settings
.claude/

# OS / editor
.DS_Store
Thumbs.db
*.swp
*~

# Python
__pycache__/
*.pyc
.venv/
venv/

# Stage 0 pipeline outputs (regenerable via `make reproduce`)
simulation/output/supplementary/
simulation/output/tables/
simulation/output/figures/

# Secrets / API keys (never commit)
.env
.env.*
!.env.example
.coverage

# Local docx backups created by apply_hallucination_fixes.py
*.docx.bak
